<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="64dp"
    android:paddingBottom="24dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <LinearLayout
        android:id="@+id/settings_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- top text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Watering"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Auto water toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Automatic Watering"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switch_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Notification toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Notification"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switch_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Live Status Display -->
        <TextView
            android:id="@+id/text_moisture_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Soil Moisture: 0%"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_water_level"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reservoir Level: 100%"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Icon button row-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Left Half: Two horizontal buttons close together -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">


                <ImageButton
                    android:id="@+id/btn_threshold"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:src="@drawable/threshold_icon"
                    android:contentDescription="Threshold Mode"
                    android:alpha="1.0" />

                <ImageButton
                    android:id="@+id/btn_interval"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:src="@drawable/interval_icon"
                    android:contentDescription="Interval Mode"
                    android:alpha="0.5" />
            </LinearLayout>

            <!-- Right Half: Single centered scheduling button -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_scheduling"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:src="@drawable/clock_icon"
                    android:contentDescription="Scheduling Settings"
                    android:alpha="0.5" />
            </LinearLayout>
        </LinearLayout>






        <!-- Moisture Threshold Container -->
        <LinearLayout
            android:id="@+id/layout_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/text_moisture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Moisture Threshold: 30%"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/seek_moisture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:max="100" />
        </LinearLayout>

        <!-- Interval Container (Initially hidden) -->
        <LinearLayout
            android:id="@+id/layout_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:visibility="gone">


            <Button
                android:id="@+id/btn_select_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Date" />

            <TextView
                android:id="@+id/text_selected_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="No date selected"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/text_scheduled_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="HH:MM"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_day_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_select_interval_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interval" />

            <TextView
                android:id="@+id/text_selected_interval_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 days"
                android:layout_marginStart="16dp"
                android:textSize="16sp" />
        </LinearLayout>


        <!-- Water Amount Slider -->
        <TextView
            android:id="@+id/text_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Watering Amount: 250ml"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seek_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="500"
            android:layout_marginBottom="24dp" />

        <!-- Rservoir Height Slider -->
        <TextView
            android:id="@+id/text_reservoir_height"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reservoir Height: 14 cm"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seek_reservoir_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:layout_marginBottom="16dp" />

        <!-- Watering Button -->
        <ImageButton
            android:id="@+id/btn_water"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/watering_icon"
            android:contentDescription="Water Now" />


        <!-- Log Button -->
        <Button
            android:id="@+id/btn_show_logs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show Logs"
            android:layout_margin="16dp" />

        <LinearLayout
            android:id="@+id/logs_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_recent_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Waterings"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_logs"
                android:layout_width="match_parent"
                android:layout_height="1200dp"
                android:layout_marginHorizontal="16dp"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>